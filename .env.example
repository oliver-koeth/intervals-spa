# intervals-spa environment configuration
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── intervals.icu ─────────────────────────────────────────────────────────────
# Your intervals.icu athlete ID (found at the bottom of /settings)
INTERVALS_ATHLETE_ID=i00000

# Your intervals.icu API key (generated in /settings → Developer Settings)
INTERVALS_API_KEY=your-api-key-here

# ── Backend server ─────────────────────────────────────────────────────────────
INTERVALS_HOST=127.0.0.1
INTERVALS_PORT=8000
INTERVALS_LOG_LEVEL=info

# ── OAuth (optional — only needed for multi-user OAuth app) ───────────────────
# INTERVALS_OAUTH_CLIENT_ID=
# INTERVALS_OAUTH_CLIENT_SECRET=
